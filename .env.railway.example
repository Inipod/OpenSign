# Railway — single-service full stack (Dockerfile at repo root)
# You need TWO Railway resources total:
#   1. This app service (GitHub repo, root directory = /)
#   2. MongoDB plugin (+ New → Database → MongoDB)
#
# After deploy, open Networking → Generate Domain on this service.
# Then set HOST_URL / SERVER_URL / REACT_APP_SERVERURL to that domain.

# ── MongoDB (reference variable from MongoDB plugin) ─────────────────────────
# MONGODB_URI=${{MongoDB.MONGO_URL}}

# ── App identity ──────────────────────────────────────────────────────────────
APP_ID=opensign
REACT_APP_APPID=opensign
MASTER_KEY=change-me-12-chars
appName=OpenSign
PARSE_MOUNT=/app
NODE_ENV=production

# Set these AFTER generating your Railway public domain:
HOST_URL=https://YOUR-DOMAIN.up.railway.app
PUBLIC_URL=https://YOUR-DOMAIN.up.railway.app
SERVER_URL=https://YOUR-DOMAIN.up.railway.app/api/app
REACT_APP_SERVERURL=https://YOUR-DOMAIN.up.railway.app/api/app

# ── Storage (required unless USE_LOCAL=true) ──────────────────────────────────
# USE_LOCAL=true
DO_SPACE=
DO_ENDPOINT=
DO_BASEURL=
DO_ACCESS_KEY_ID=
DO_SECRET_ACCESS_KEY=
DO_REGION=

# ── Email (Mailgun OR SMTP) ───────────────────────────────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_SENDER=
# SMTP_ENABLE=true
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER_EMAIL=
# SMTP_PASS=

# ── Document signing certificate ──────────────────────────────────────────────
PFX_BASE64=
PASS_PHRASE=
